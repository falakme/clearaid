# ClarityAI environment configuration
# Copy to `.env` for local development, or set these in the Coolify UI.
#
# ClarityAI is STATELESS — there is no database. Documents are processed in
# memory and never persisted.

# --- Cognitive engine (NVIDIA Build API) ---
# Get a key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b

# --- Brave Search (agentic "Verified Local Support" recommendation) ---
# Get a key at https://api-dashboard.search.brave.com. Optional: when empty,
# the recommendation step is skipped and no "Verified Local Support" card
# is shown. The core translation always works without it.
BRAVE_API_KEY=

# --- Microsoft Azure Cognitive Services — Text-to-Speech (read-aloud) ---
# Get a key in the Azure portal (Speech resource). Optional: when empty, the
# frontend falls back to the browser's built-in Web Speech synthesis, so
# read-aloud still works. Read-aloud is English-only.
AZURE_TTS_KEY=
AZURE_TTS_ENDPOINT=https://centralindia.api.cognitive.microsoft.com/cognitiveservices/v1
AZURE_TTS_VOICE=en-US-JennyNeural

# --- Backend service config ---
# Comma-separated CORS origins. Only needed if the browser calls the backend
# DIRECTLY (i.e. you set an absolute NEXT_PUBLIC_API_BASE_URL below). With the
# default same-origin proxy this is unused.
CORS_ORIGINS=http://localhost:3000
# OCR upload ceiling (MB).
MAX_UPLOAD_MB=10

# --- Frontend -> backend wiring ---
# RECOMMENDED (Coolify / any reverse proxy): leave NEXT_PUBLIC_API_BASE_URL
# EMPTY. The browser then calls the frontend's own origin (/api/*), and the
# Next.js server proxies to the backend via BACKEND_INTERNAL_URL. This avoids
# CORS and HTTPS->HTTP mixed content, and keeps the backend off the public net.
#
# Only set this to a full absolute https URL if you intentionally want the
# browser to hit the backend directly — then also set CORS_ORIGINS above and
# rebuild (this value is baked in at BUILD time).
NEXT_PUBLIC_API_BASE_URL=
# Internal URL the Next.js server uses to reach the backend container.
BACKEND_INTERNAL_URL=http://backend:8000
