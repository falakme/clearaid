# ClearAid environment configuration
# Copy to `.env` for local development, or set these in the Coolify UI.

# --- Postgres ---
POSTGRES_USER=clearaid
POSTGRES_PASSWORD=clearaid_dev_pw
POSTGRES_DB=clearaid

# --- Backend (FastAPI) ---
# NOTE: This DB stores ONLY non-PII mocked disaster alerts. No user data.
DATABASE_URL=postgresql+psycopg://clearaid:clearaid_dev_pw@db:5432/clearaid

# NVIDIA Build API — get a key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=google/gemma-3n-e4b-it

# Comma-separated CORS origins for the browser app
CORS_ORIGINS=http://localhost:3000

# Protects the admin mock-alert endpoints (demo control panel)
ADMIN_API_KEY=clearaid_admin_dev_key

# --- Frontend (Next.js) ---
# Public base URL the browser uses to reach the backend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Internal URL Next.js server uses to proxy admin calls (container network)
BACKEND_INTERNAL_URL=http://backend:8000

# --- Auth (Clerk) — OPTIONAL ---
# Leave empty to run with auth disabled (gated modules stay open in demo mode).
# Get keys at https://dashboard.clerk.com. The publishable key is baked into
# the browser bundle at build time; the secret key is server-side only.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
