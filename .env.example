# ClearAid environment configuration
# Copy to `.env` for local development, or set these in the Coolify UI.

# --- Postgres ---
POSTGRES_USER=clearaid
POSTGRES_PASSWORD=clearaid_dev_pw
POSTGRES_DB=clearaid

# --- Backend (FastAPI) ---
# NOTE: This DB stores ONLY non-PII mocked disaster alerts. No user data.
DATABASE_URL=postgresql+psycopg://clearaid:clearaid_dev_pw@db:5432/clearaid

# NVIDIA Build API — get a key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=google/gemma-3n-e4b-it

# Brave Search API — recommendation engine for official .gov relief links.
# Get a key at https://api-dashboard.search.brave.com. Optional: when empty,
# "Recommended actions" simply renders nothing.
BRAVE_API_KEY=

# Web Push (VAPID). Generate a keypair once, e.g.:
#   python -c "from py_vapid import Vapid01; v=Vapid01(); v.generate_keys(); import base64; print(base64.urlsafe_b64encode(v.private_pem()).decode())"
# or use `npx web-push generate-vapid-keys`. Optional: when empty, push is
# disabled (subscriptions are still accepted but no notifications are sent).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@clearaid.app

# Comma-separated CORS origins for the browser app.
# Only needed if the browser calls the backend DIRECTLY (i.e. you set an
# absolute NEXT_PUBLIC_API_BASE_URL below). With the default same-origin proxy
# this is unused. For direct mode, set it to your frontend URL, e.g.
# CORS_ORIGINS=https://clearaid.falak.me
CORS_ORIGINS=http://localhost:3000

# Protects the admin mock-alert endpoints (demo control panel)
ADMIN_API_KEY=clearaid_admin_dev_key

# --- Frontend (Next.js) ---
# RECOMMENDED (Coolify / any reverse proxy): leave NEXT_PUBLIC_API_BASE_URL
# EMPTY. The browser then calls the frontend's own origin (/api/*), and the
# Next.js server proxies to the backend via BACKEND_INTERNAL_URL. This avoids
# CORS, HTTPS->HTTP mixed content, and baking a public backend URL into the
# bundle. The backend does NOT need to be exposed publicly in this mode.
#
# Only set this to a full absolute https URL (e.g.
# https://backend.clearaid.falak.me) if you intentionally want the browser to
# hit the backend directly — then you must also set CORS_ORIGINS above and
# rebuild (this value is baked in at BUILD time, so it must be a Coolify
# "Build Variable").
NEXT_PUBLIC_API_BASE_URL=
# Internal URL the Next.js server uses to reach the backend container.
BACKEND_INTERNAL_URL=http://backend:8000

# Test/demo mode — exposes "Simulate Location" on onboarding and synthetic
# demo-document loaders on the intake screen. Set to "true" for demos.
# (NEXT_PUBLIC_* is baked into the browser bundle at BUILD time.)
NEXT_PUBLIC_TEST_MODE=false

# --- Auth (Clerk) — OPTIONAL ---
# Leave empty to run with auth disabled (gated modules stay open in demo mode).
# Get keys at https://dashboard.clerk.com. The publishable key is baked into
# the browser bundle at build time; the secret key is server-side only.
#
# ROLE-BASED ACCESS: roles are stored in Clerk **publicMetadata**:
#   { "role": "admin" }  -> /admin console
#   { "role": "er" }     -> /er-dashboard (ER responders)
#   (anything else)      -> standard user
# Set this in the Clerk dashboard (user -> Metadata -> Public). The
# CLERK_SECRET_KEY is required so the middleware/layouts can read it server-side.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
